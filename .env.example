# Copy this file to `.env` and fill in your own values.
# Do NOT commit `.env` — it is git-ignored on purpose.

# --- Gemini (optional) -------------------------------------------------
# If you don't have a Gemini key, leave the placeholder.
# The Copilot will still run; it falls back to local deterministic text
# for narratives/explanations, and to TF-IDF excerpts for policy Q&A.
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# --- Retrieval ---------------------------------------------------------
# This project uses a local TF-IDF retriever over the policy PDFs.
# Google embeddings are intentionally disabled to avoid external
# embedding-model failures during a local demo.
GOOGLE_EMBEDDING_MODEL=disabled-local-tfidf

# Legacy / reserved — not required when TF-IDF is in use.
CHROMA_PERSIST_DIR=./apps/api/chroma_db

# --- Paths -------------------------------------------------------------
POLICY_DOCS_DIR=./data/policies
GOLD_LAKEHOUSE_PATH=./lakehouse/gold
AUDIT_LOG_PATH=./apps/api/audit.log
